<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <appSettings>
    <add key="DatasetPath" value="Data\AirPi.csv" />
    <add key="RowLimit"    value="110" />
    <add key="LogPath"     value="Data\client_log.txt" />
  </appSettings>

  <system.serviceModel>

    <bindings>
      <netTcpBinding>
        <binding name="SensorTcpBinding"
                 closeTimeout="00:01:00"
                 openTimeout="00:01:00"
                 sendTimeout="00:05:00"
                 receiveTimeout="00:10:00"
                 maxBufferPoolSize="2147483647"
                 maxBufferSize="2147483647"
                 maxReceivedMessageSize="2147483647"
                 transferMode="Buffered">
          <readerQuotas maxDepth="2147483647"
                        maxStringContentLength="2147483647"
                        maxArrayLength="2147483647"
                        maxBytesPerRead="2147483647"
                        maxNameTableCharCount="2147483647" />
          <reliableSession enabled="false" />
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>

    <client>
      <endpoint name="SensorService"
                address="net.tcp://localhost:4000/SensorService"
                binding="netTcpBinding"
                bindingConfiguration="SensorTcpBinding"
                contract="Common.ISensorService" />
    </client>

  </system.serviceModel>
</configuration>
